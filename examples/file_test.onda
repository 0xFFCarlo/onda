: print_board ( board | x y )
  0 -> y 
  while y 9 < do
    0 -> x
    while x 9 < do
      board y 9 * x + @ . " " .s
      x ++ -> x
    end
    "\n" .s
    y ++ -> y
  end
;

: save_file ( filename | i board fid )

  9 9 * malloc -> board
  board 0 memset

  filename "r" fopen -> fid
  if fid not then
    "Error opening file " .s filename .s "\n" .s exit
  end

  #0 -> i
  #while i 9 < do
  #  board 9 1 fid fread drop
  #  i ++ -> i
  #end

  board print_board

  fid fclose
;

: main "output.txt" save_file ;
